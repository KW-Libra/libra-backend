# Spring profiles
SPRING_PROFILES_ACTIVE=local

# Database (libra-agent 의 Postgres docker 와 매칭)
DB_URL=jdbc:postgresql://localhost:5432/libra
DB_USER=libra
DB_PASSWORD=libra

# Server
SERVER_PORT=8080

# JWT — 운영 시 반드시 256bit+ 랜덤으로 교체
JWT_SECRET=replace-this-with-a-long-random-string-min-256-bits-please-change-it-in-prod
JWT_TTL_SECONDS=86400

# CORS — Vue dev server / Amplify 도메인
FRONTEND_ORIGIN=http://localhost:5173

# Downstream
AGENT_BASE_URL=http://localhost:8000

# Public backtest reports (private S3, served through backend API)
LIBRA_BACKTEST_PUBLIC_RSS_3Y_VALIDATION_URI=s3://libra-backtests-271030592697-ap-northeast-2/backtests/public-rss-3y/validation.json
LIBRA_BACKTEST_S3_REGION=ap-northeast-2
LIBRA_BACKTEST_PUBLIC_RSS_3Y_CACHE_TTL=5m

# Korea Investment & Securities Open API
KIS_ENABLED=false
KIS_TRADING_ENABLED=false
KIS_ENVIRONMENT=paper
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NUMBER=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_HTS_ID=
KIS_MAX_ORDER_QUANTITY=1000
KIS_MAX_ORDER_AMOUNT=10000000
KIS_ALLOWED_SYMBOLS=
KIS_CREDENTIAL_ENCRYPTION_KEY=
